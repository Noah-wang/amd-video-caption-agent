AI_PROVIDER=fireworks
FIREWORKS_API_KEY=your-fireworks-key
FIREWORKS_VISION_MODEL=accounts/fireworks/models/minimax-m3
FIREWORKS_TEXT_MODEL=accounts/fireworks/models/gpt-oss-120b
PIPELINE_MODE=single_pass
CAPTION_SELF_REVIEW=0
FRAME_WIDTH=384
USE_CONTACT_SHEET=1
# Optional: adaptive is fastest; keyframes samples candidates every second.
# FRAME_SELECTION_MODE=adaptive
# FRAME_CANDIDATE_INTERVAL_SECONDS=1
# MAX_CANDIDATE_FRAMES=120
# MAX_VISION_FRAMES=4
